# ── Telegram Bot ──────────────────────────────────────────────────────────
# Step 1: Open Telegram → search @BotFather → /newbot → follow steps → copy TOKEN
# Step 2: Send any message to your new bot
# Step 3: Visit https://api.telegram.org/bot<TOKEN>/getUpdates
#         Find "chat":{"id": 123456789} → that number is your CHAT_ID
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── TradingView Login (optional but recommended) ───────────────────────────
# Authenticated sessions get more historical bars and no rate limits.
# Use your TradingView username and password.
TV_USERNAME=your_tradingview_username
TV_PASSWORD=your_tradingview_password
